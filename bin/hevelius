#!/usr/bin/env python3

"""
Provides command line interface to the Hevelius project.
"""

import sys
import argparse

sys.path.append(".")

# pylint: disable=wrong-import-position
from hevelius.cmd_basic import db_version, hevelius_version, config_show, backup
from hevelius.cmd_stats import stats, histogram_show, groups
from hevelius.cmd_db_migrate import migrate
from hevelius.cmd_repo import repo
from hevelius.cmd_catalog import catalog, format_get
from hevelius.cmd_equipment import (
    list_filters,
    list_sensors,
    list_projects,
    show_project,
    add_filter,
    edit_filter,
    set_filter_active,
    add_sensor,
    edit_sensor,
)


def run():
    """
    Parses command line arguments and runs the appropriate command.
    """

    parser = argparse.ArgumentParser("hevelius")
    subparsers = parser.add_subparsers(help="commands", dest="command")

    subparsers.add_parser('config', help="Shows current Hevelius (DB,file repository) configuration.")
    subparsers.add_parser('version', help="Shows the current Hevelius version.")

    db_parser = subparsers.add_parser('db', help="Manages database")
    db_subparsers = db_parser.add_subparsers(help="Commands related to database", dest="db_command")
    db_subparsers.add_parser('version', help="Shows the current DB schema version.")  # version_parser
    db_subparsers.add_parser('backup', help="Generates DB backup.")  # backup_parser
    migrate_parser = db_subparsers.add_parser('migrate', help="Migrate to the latest DB schema")
    migrate_parser.add_argument("-t", "--dry-run", help="Don't do the actual DB upsert", action='store_true')
    db_subparsers.add_parser('stats', help="Show database statistics")  # stats_parser

    repo_parser = subparsers.add_parser('repo', help="Manages files repository on local storage.")
    repo_parser.add_argument('-f', "--file", help="Reads a single FITS file", type=str)
    repo_parser.add_argument("-l", "--list", help="Reads a list of FITS files (one filename per line)", type=str)
    repo_parser.add_argument("-d", "--dir",   help="Reads all FITS files recursively", type=str)
    repo_parser.add_argument("-s", "--show-header", help="Displays all entries in FITS header", action='store_true')
    repo_parser.add_argument("-t", "--dry-run", help="Don't do the actual DB upsert", action='store_true')
    repo_parser.add_argument("--sanity-db", help="Goes through the list of tasks in a database and checks if all files are present", action='store_true')
    repo_parser.add_argument("--sanity-files", help="Goes through the list of files and check if related tasks are present", action='store_true')
    repo_parser.add_argument("--min-task-id", help="Minimum task ID to check (for sanity-db)", type=int)
    repo_parser.add_argument("--max-task-id", help="Maximum task ID to check (for sanity-db)", type=int)
    repo_parser.add_argument("--delete-invalid", help="Delete invalid tasks (no filename or missing file) when using sanity-db", action='store_true')

    data_parser = subparsers.add_parser('data', help="Explores, analyses and digs through available data (data mining)")
    data_subparsers = data_parser.add_subparsers(help="Commands related to data", dest="data_command")
    data_subparsers.add_parser('distrib', help="Shows photos distribution")  # distrib_parser
    groups_parser = data_subparsers.add_parser('groups', help="Shows frames' groups")
    groups_parser.add_argument("-m", "--min", help="Minimum number of frames in a group", type=int, default=200)

    # Default values set to the first Messier object
    catalog_parser = data_subparsers.add_parser('catalog', help="Finds astronomical objects in a catalog")
    catalog_parser.add_argument('-r', "--ra", help="Right Ascension (HH MM [SS] format)", type=str, default="05 34 31")
    catalog_parser.add_argument('-d', "--decl", help="Declination of the image searched (+DD MM SS format)", type=str, default="+22 00 52")
    catalog_parser.add_argument('-p', "--proximity", help="radius of an area to look at (in degrees)", type=float, default=1.0)
    catalog_parser.add_argument('-f', "--format", help="format of the frames list output: none, filenames, csv, brief, full", type=format_get, default="brief")
    catalog_parser.add_argument('-o', "--object", help="catalog object to look for", type=str, default="")
    catalog_parser.add_argument('-b', "--bin", help="filtering: binning of the frames to look for (1..4, 0 means any)", type=int, default=0)
    catalog_parser.add_argument("--focal", help="filtering: focal length (mm)", type=int, default=0)
    catalog_parser.add_argument("--resx", help="filtering: X resolution (pixels)", type=int, default=0)
    catalog_parser.add_argument("--resy", help="filtering: y resolution (pixels)", type=int, default=0)
    catalog_parser.add_argument("--sensor", help="filtering: specifies sensor by its name (name in sensors table)", type=str, default="")
    catalog_parser.add_argument("--sensor-id", help="filtering: specifies sensor by its id (sensor_id in sensors table)", type=int, default=0)

    filters_parser = subparsers.add_parser('filters', help="List optical filters")
    filters_parser.add_argument('--active-only', action='store_true', help="Show only active filters")

    filter_parser = subparsers.add_parser('filter', help="Add, edit, or set active state of a filter")
    filter_sub = filter_parser.add_subparsers(dest='filter_command', help="Filter subcommand")
    filter_add = filter_sub.add_parser('add', help="Add a new filter (short_name full_name)")
    filter_add.add_argument('short_name', help="Short name (max 8 chars)")
    filter_add.add_argument('full_name', nargs='?', default=None, help="Full filter name (e.g. H-alpha)")
    filter_add.add_argument('--url', help="URL for filter info")
    filter_add.add_argument('--active', action='store_true', default=True, help="Filter is active (default)")
    filter_add.add_argument('--inactive', action='store_true', help="Create filter as inactive")
    filter_edit = filter_sub.add_parser('edit', help="Edit an existing filter")
    filter_edit.add_argument('filter_id', type=int, help="Filter ID to edit")
    filter_edit.add_argument('--short-name', help="Short name (max 8 chars)")
    filter_edit.add_argument('--full-name', help="Full filter name")
    filter_edit.add_argument('--url', help="URL for filter info")
    filter_edit.add_argument('--active', action='store_true', help="Set filter active")
    filter_edit.add_argument('--inactive', action='store_true', help="Set filter inactive")
    filter_activate = filter_sub.add_parser('activate', help="Make filter active")
    filter_activate.add_argument('filter_id', type=int, help="Filter ID")
    filter_deactivate = filter_sub.add_parser('deactivate', help="Make filter inactive")
    filter_deactivate.add_argument('filter_id', type=int, help="Filter ID")

    sensors_parser = subparsers.add_parser('sensors', help="List sensors (cameras)")
    sensors_parser.add_argument('--active-only', action='store_true', help="Show only active sensors")
    sensors_parser.add_argument('--sort-by', choices=['pixel_x', 'pixel_y', 'name', 'vendor', 'width', 'height', 'resx', 'resy', 'sensor_id'],
                                default='sensor_id', help="Sort by field")
    sensors_parser.add_argument('--sort-order', choices=['asc', 'desc'], default='asc', help="Sort order")

    sensor_parser = subparsers.add_parser('sensor', help="Add or edit a sensor (camera)")
    sensor_sub = sensor_parser.add_subparsers(dest='sensor_command', help="Sensor subcommand")
    sensor_add = sensor_sub.add_parser('add', help="Add a new sensor (resx, resy, pixel-x, pixel-y required)")
    sensor_add.add_argument('name', help="Sensor/camera name")
    sensor_add.add_argument('--resx', type=int, required=True, help="Resolution X (pixels)")
    sensor_add.add_argument('--resy', type=int, required=True, help="Resolution Y (pixels)")
    sensor_add.add_argument('--pixel-x', type=float, required=True, help="Pixel size X (microns)")
    sensor_add.add_argument('--pixel-y', type=float, required=True, help="Pixel size Y (microns)")
    sensor_add.add_argument('--bits', type=int, default=0, help="Bit depth (default: 0)")
    sensor_add.add_argument('--width', type=float, help="Sensor width (mm)")
    sensor_add.add_argument('--height', type=float, help="Sensor height (mm)")
    sensor_add.add_argument('--vendor', help="Vendor name")
    sensor_add.add_argument('--url', help="URL for sensor info")
    sensor_add.add_argument('--active', action='store_true', default=True, help="Sensor is active (default)")
    sensor_add.add_argument('--inactive', action='store_true', help="Create sensor as inactive")
    sensor_edit = sensor_sub.add_parser('edit', help="Edit an existing sensor")
    sensor_edit.add_argument('sensor_id', type=int, help="Sensor ID to edit")
    sensor_edit.add_argument('--name', help="Sensor name")
    sensor_edit.add_argument('--resx', type=int, help="Resolution X (pixels)")
    sensor_edit.add_argument('--resy', type=int, help="Resolution Y (pixels)")
    sensor_edit.add_argument('--pixel-x', type=float, help="Pixel size X (microns)")
    sensor_edit.add_argument('--pixel-y', type=float, help="Pixel size Y (microns)")
    sensor_edit.add_argument('--bits', type=int, help="Bit depth")
    sensor_edit.add_argument('--width', type=float, help="Sensor width (mm)")
    sensor_edit.add_argument('--height', type=float, help="Sensor height (mm)")
    sensor_edit.add_argument('--vendor', help="Vendor name")
    sensor_edit.add_argument('--url', help="URL for sensor info")
    sensor_edit.add_argument('--active', action='store_true', help="Set sensor active")
    sensor_edit.add_argument('--inactive', action='store_true', help="Set sensor inactive")

    projects_parser = subparsers.add_parser('projects', help="List or show projects")
    projects_parser.add_argument('project_id', nargs='?', type=int, help="If given, show single project by ID")
    projects_parser.add_argument('--active-only', action='store_true', help="(Reserved for future use)")

    args = parser.parse_args()

    # db commands: version, migrate, backup, stats
    if args.command == "db":
        if args.db_command == "version":
            return db_version()  # see cmd_basic.py
        if args.db_command == "migrate":
            return migrate(args)  # see cmd_db_migrate.py
        if args.db_command == "backup":
            return backup(args)  # see cmd_backup.py
        if args.db_command == "stats":
            return stats()  # see cmd_stats.py
        return parser.print_help()
    if args.command == "data":
        if args.data_command == "distrib":
            return histogram_show(args)  # see cmd_stats.py
        if args.data_command == "groups":
            return groups(args)  # see cmd_stats.py
        if args.data_command == "catalog":
            return catalog(args)  # see cmd_catalog.py
        return parser.print_help()
    if args.command == "config":
        return config_show()  # see cmd_basic.py
    if args.command == "repo":
        return repo(args)  # see cmd_repo.py
    if args.command == "version":
        return version()
    if args.command == "filters":
        list_filters(active_only=args.active_only)
        return 0
    if args.command == "filter":
        if args.filter_command == "add":
            active = getattr(args, 'active', True) and not getattr(args, 'inactive', False)
            return 0 if add_filter(args.short_name, args.full_name, args.url, active) is not None else 1
        if args.filter_command == "edit":
            active = None
            if getattr(args, 'active', False):
                active = True
            if getattr(args, 'inactive', False):
                active = False
            return 0 if edit_filter(args.filter_id, args.short_name, args.full_name, args.url, active) else 1
        if args.filter_command == "activate":
            return 0 if set_filter_active(args.filter_id, True) else 1
        if args.filter_command == "deactivate":
            return 0 if set_filter_active(args.filter_id, False) else 1
        return filter_parser.print_help() or 1
    if args.command == "sensors":
        list_sensors(active_only=args.active_only, sort_by=args.sort_by, sort_order=args.sort_order)
        return 0
    if args.command == "sensor":
        if args.sensor_command == "add":
            active = getattr(args, 'active', True) and not getattr(args, 'inactive', False)
            return 0 if add_sensor(
                args.name,
                resx=args.resx,
                resy=args.resy,
                pixel_x=args.pixel_x,
                pixel_y=args.pixel_y,
                bits=getattr(args, 'bits', 0),
                width=getattr(args, 'width', None),
                height=getattr(args, 'height', None),
                vendor=getattr(args, 'vendor', None),
                url=getattr(args, 'url', None),
                active=active
            ) is not None else 1
        if args.sensor_command == "edit":
            active = None
            if getattr(args, 'active', False):
                active = True
            if getattr(args, 'inactive', False):
                active = False
            return 0 if edit_sensor(
                args.sensor_id,
                name=getattr(args, 'name', None),
                resx=getattr(args, 'resx', None),
                resy=getattr(args, 'resy', None),
                pixel_x=getattr(args, 'pixel_x', None),
                pixel_y=getattr(args, 'pixel_y', None),
                bits=getattr(args, 'bits', None),
                width=getattr(args, 'width', None),
                height=getattr(args, 'height', None),
                vendor=getattr(args, 'vendor', None),
                url=getattr(args, 'url', None),
                active=active
            ) else 1
        return sensor_parser.print_help() or 1
    if args.command == "projects":
        if args.project_id is not None:
            return show_project(args.project_id) or 0
        list_projects()
        return 0
    return parser.print_help()


def version():
    """
    Prints the version of the Hevelius project.
    """
    print(f"Hevelius {hevelius_version()}")


if __name__ == '__main__':
    run()
