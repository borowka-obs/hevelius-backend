#!/usr/bin/env python3

"""
Provides command line interface to the Hevelius project.
"""

import sys
import argparse

sys.path.append(".")

# pylint: disable=wrong-import-position
from hevelius.cmd_basic import db_version, hevelius_version, config_show, backup
from hevelius.cmd_stats import stats, histogram_show, groups
from hevelius.cmd_db_migrate import migrate
from hevelius.cmd_repo import repo
from hevelius.cmd_catalog import catalog, format_get
from hevelius.cmd_equipment import (
    list_filters,
    list_sensors,
    list_projects,
    show_project,
    add_project,
    edit_project,
    get_filter_id_by_short_name,
    add_project_subframe,
    edit_project_subframe,
    remove_project_subframe,
    project_stats,
    add_task_to_project,
    remove_task_from_project,
    add_filter,
    edit_filter,
    add_sensor,
    edit_sensor,
    list_telescopes,
    add_telescope,
    edit_telescope,
    show_telescope,
    set_telescope_sensor,
    add_telescope_filter,
    remove_telescope_filter,
)


def run():
    """
    Parses command line arguments and runs the appropriate command.
    """

    parser = argparse.ArgumentParser("hevelius")
    subparsers = parser.add_subparsers(help="commands", dest="command")

    subparsers.add_parser('config', help="Shows current Hevelius (DB,file repository) configuration.")
    subparsers.add_parser('version', help="Shows the current Hevelius version.")

    db_parser = subparsers.add_parser('db', help="Manages database")
    db_subparsers = db_parser.add_subparsers(help="Commands related to database", dest="db_command")
    db_subparsers.add_parser('version', help="Shows the current DB schema version.")  # version_parser
    db_subparsers.add_parser('backup', help="Generates DB backup.")  # backup_parser
    migrate_parser = db_subparsers.add_parser('migrate', help="Migrate to the latest DB schema")
    migrate_parser.add_argument("-t", "--dry-run", help="Don't do the actual DB upsert", action='store_true')
    db_subparsers.add_parser('stats', help="Show database statistics")  # stats_parser

    repo_parser = subparsers.add_parser('repo', help="Manages files repository on local storage.")
    repo_parser.add_argument('-f', "--file", help="Reads a single FITS file", type=str)
    repo_parser.add_argument("-l", "--list", help="Reads a list of FITS files (one filename per line)", type=str)
    repo_parser.add_argument("-d", "--dir",   help="Reads all FITS files recursively", type=str)
    repo_parser.add_argument("-s", "--show-header", help="Displays all entries in FITS header", action='store_true')
    repo_parser.add_argument("-t", "--dry-run", help="Don't do the actual DB upsert", action='store_true')
    repo_parser.add_argument("--sanity-db", help="Goes through the list of tasks in a database and checks if all files are present", action='store_true')
    repo_parser.add_argument("--sanity-files", help="Goes through the list of files and check if related tasks are present", action='store_true')
    repo_parser.add_argument("--min-task-id", help="Minimum task ID to check (for sanity-db)", type=int)
    repo_parser.add_argument("--max-task-id", help="Maximum task ID to check (for sanity-db)", type=int)
    repo_parser.add_argument("--delete-invalid", help="Delete invalid tasks (no filename or missing file) when using sanity-db", action='store_true')

    data_parser = subparsers.add_parser('data', help="Explores, analyses and digs through available data (data mining)")
    data_subparsers = data_parser.add_subparsers(help="Commands related to data", dest="data_command")
    data_subparsers.add_parser('distrib', help="Shows photos distribution")  # distrib_parser
    groups_parser = data_subparsers.add_parser('groups', help="Shows frames' groups")
    groups_parser.add_argument("-m", "--min", help="Minimum number of frames in a group", type=int, default=200)

    # Default values set to the first Messier object
    catalog_parser = data_subparsers.add_parser('catalog', help="Finds astronomical objects in a catalog")
    catalog_parser.add_argument('-r', "--ra", help="Right Ascension (HH MM [SS] format)", type=str, default="05 34 31")
    catalog_parser.add_argument('-d', "--decl", help="Declination of the image searched (+DD MM SS format)", type=str, default="+22 00 52")
    catalog_parser.add_argument('-p', "--proximity", help="radius of an area to look at (in degrees)", type=float, default=1.0)
    catalog_parser.add_argument('-f', "--format", help="format of the frames list output: none, filenames, csv, brief, full", type=format_get, default="brief")
    catalog_parser.add_argument('-o', "--object", help="catalog object to look for", type=str, default="")
    catalog_parser.add_argument('-b', "--bin", help="filtering: binning of the frames to look for (1..4, 0 means any)", type=int, default=0)
    catalog_parser.add_argument("--focal", help="filtering: focal length (mm)", type=int, default=0)
    catalog_parser.add_argument("--resx", help="filtering: X resolution (pixels)", type=int, default=0)
    catalog_parser.add_argument("--resy", help="filtering: y resolution (pixels)", type=int, default=0)
    catalog_parser.add_argument("--sensor", help="filtering: specifies sensor by its name (name in sensors table)", type=str, default="")
    catalog_parser.add_argument("--sensor-id", help="filtering: specifies sensor by its id (sensor_id in sensors table)", type=int, default=0)

    filters_parser = subparsers.add_parser('filters', help="List optical filters")
    filters_parser.add_argument('--active-only', action='store_true', help="Show only active filters")
    filters_parser.add_argument('--sort-by', choices=['filter_id', 'short_name', 'full_name', 'active'],
                                default='filter_id', help="Sort by field")
    filters_parser.add_argument('--sort-order', choices=['asc', 'desc'], default='asc', help="Sort order")

    filter_parser = subparsers.add_parser('filter', help="Add, edit, or set active state of a filter")
    filter_sub = filter_parser.add_subparsers(dest='filter_command', help="Filter subcommand")
    filter_add = filter_sub.add_parser('add', help="Add a new filter (short_name full_name)")
    filter_add.add_argument('short_name', help="Short name (max 8 chars)")
    filter_add.add_argument('full_name', nargs='?', default=None, help="Full filter name (e.g. H-alpha)")
    filter_add.add_argument('--url', help="URL for filter info")
    filter_add.add_argument('--active', action='store_true', default=True, help="Filter is active (default)")
    filter_add.add_argument('--inactive', action='store_true', help="Create filter as inactive")
    filter_edit = filter_sub.add_parser('edit', help="Edit an existing filter")
    filter_edit.add_argument('filter_id', type=int, help="Filter ID to edit")
    filter_edit.add_argument('--short-name', help="Short name (max 8 chars)")
    filter_edit.add_argument('--full-name', help="Full filter name")
    filter_edit.add_argument('--url', help="URL for filter info")
    filter_edit.add_argument('--active', action='store_true', help="Set filter active")
    filter_edit.add_argument('--inactive', action='store_true', help="Set filter inactive")

    sensors_parser = subparsers.add_parser('sensors', help="List sensors (cameras)")
    sensors_parser.add_argument('--active-only', action='store_true', help="Show only active sensors")
    sensors_parser.add_argument('--sort-by', choices=['pixel_x', 'pixel_y', 'name', 'vendor', 'width', 'height', 'resx', 'resy', 'sensor_id'],
                                default='sensor_id', help="Sort by field")
    sensors_parser.add_argument('--sort-order', choices=['asc', 'desc'], default='asc', help="Sort order")

    sensor_parser = subparsers.add_parser('sensor', help="Add or edit a sensor (camera)")
    sensor_sub = sensor_parser.add_subparsers(dest='sensor_command', help="Sensor subcommand")
    sensor_add = sensor_sub.add_parser('add', help="Add a new sensor (resx, resy, pixel-x, pixel-y required)")
    sensor_add.add_argument('name', help="Sensor/camera name")
    sensor_add.add_argument('--resx', type=int, required=True, help="Resolution X (pixels)")
    sensor_add.add_argument('--resy', type=int, required=True, help="Resolution Y (pixels)")
    sensor_add.add_argument('--pixel-x', type=float, required=True, help="Pixel size X (microns)")
    sensor_add.add_argument('--pixel-y', type=float, required=True, help="Pixel size Y (microns)")
    sensor_add.add_argument('--bits', type=int, default=0, help="Bit depth (default: 0)")
    sensor_add.add_argument('--width', type=float, help="Sensor width (mm)")
    sensor_add.add_argument('--height', type=float, help="Sensor height (mm)")
    sensor_add.add_argument('--vendor', help="Vendor name")
    sensor_add.add_argument('--url', help="URL for sensor info")
    sensor_add.add_argument('--active', action='store_true', default=True, help="Sensor is active (default)")
    sensor_add.add_argument('--inactive', action='store_true', help="Create sensor as inactive")
    sensor_edit = sensor_sub.add_parser('edit', help="Edit an existing sensor")
    sensor_edit.add_argument('sensor_id', type=int, help="Sensor ID to edit")
    sensor_edit.add_argument('--name', help="Sensor name")
    sensor_edit.add_argument('--resx', type=int, help="Resolution X (pixels)")
    sensor_edit.add_argument('--resy', type=int, help="Resolution Y (pixels)")
    sensor_edit.add_argument('--pixel-x', type=float, help="Pixel size X (microns)")
    sensor_edit.add_argument('--pixel-y', type=float, help="Pixel size Y (microns)")
    sensor_edit.add_argument('--bits', type=int, help="Bit depth")
    sensor_edit.add_argument('--width', type=float, help="Sensor width (mm)")
    sensor_edit.add_argument('--height', type=float, help="Sensor height (mm)")
    sensor_edit.add_argument('--vendor', help="Vendor name")
    sensor_edit.add_argument('--url', help="URL for sensor info")
    sensor_edit.add_argument('--active', action='store_true', help="Set sensor active")
    sensor_edit.add_argument('--inactive', action='store_true', help="Set sensor inactive")

    projects_parser = subparsers.add_parser('projects', help="List projects")
    projects_parser.add_argument('project_id', nargs='?', type=int, help="If given, show single project by ID")
    projects_parser.add_argument('--scope-id', type=int, default=None, help="Filter by telescope (scope) ID")
    projects_parser.add_argument('--active-only', action='store_true', help="(Reserved for future use)")

    project_parser = subparsers.add_parser('project', help="Add, edit, show project or manage subframes")
    project_sub = project_parser.add_subparsers(dest='project_command', help="Project subcommand")
    project_add = project_sub.add_parser('add', help="Add a new project (name and scope_id required; ra/dec from catalog if omitted)")
    project_add.add_argument('name', help="Project name (used for catalog lookup if ra/dec not given)")
    project_add.add_argument('--scope-id', type=int, required=True, help="Telescope (scope) ID")
    project_add.add_argument('--ra', type=float, default=None, help="RA in hours (omit to resolve from catalog by name)")
    project_add.add_argument('--dec', type=float, default=None, help="Declination in degrees (omit to resolve from catalog by name)")
    project_add.add_argument('--description', default='', help="Project description")
    project_add.add_argument('--active', action='store_true', default=True, help="Project is active (default)")
    project_add.add_argument('--inactive', action='store_true', help="Create project as inactive")
    project_edit = project_sub.add_parser('edit', help="Edit an existing project")
    project_edit.add_argument('project_id', type=int, help="Project ID to edit")
    project_edit.add_argument('--name', help="Project name")
    project_edit.add_argument('--scope-id', type=int, default=None, help="Telescope (scope) ID")
    project_edit.add_argument('--description', default=None, help="Project description")
    project_edit.add_argument('--ra', type=float, default=None, help="RA in hours")
    project_edit.add_argument('--dec', type=float, default=None, help="Declination in degrees")
    project_edit.add_argument('--active', action='store_true', help="Set project active")
    project_edit.add_argument('--inactive', action='store_true', help="Set project inactive")
    project_show = project_sub.add_parser('show', help="Show project details")
    project_show.add_argument('project_id', type=int, help="Project ID")
    subframe_parser = project_sub.add_parser('subframe', help="Add, edit, or remove a subframe")
    subframe_sub = subframe_parser.add_subparsers(dest='subframe_command', help="Subframe subcommand")
    subframe_add = subframe_sub.add_parser('add', help="Add a subframe to a project")
    subframe_add.add_argument('project_id', type=int, help="Project ID")
    subframe_add.add_argument('--filter', type=str, default=None, help="Filter by short name (use this OR --filter-id, not both)")
    subframe_add.add_argument('--filter-id', type=int, default=None, help="Filter ID (use this OR --filter, not both)")
    subframe_add.add_argument('--exposure-time', type=float, required=True, help="Exposure time (seconds)")
    subframe_add.add_argument('--goal-count', type=int, default=None, help="Target number of subframes")
    subframe_add.add_argument('--active', action='store_true', default=True, help="Subframe active (default)")
    subframe_add.add_argument('--inactive', action='store_true', help="Create subframe as inactive")
    subframe_edit = subframe_sub.add_parser('edit', help="Edit a subframe")
    subframe_edit.add_argument('project_id', type=int, help="Project ID")
    subframe_edit.add_argument('subframe_id', type=int, help="Subframe ID (from project show)")
    subframe_edit.add_argument('--filter', type=str, default=None, help="Filter by short name (use this OR --filter-id, not both)")
    subframe_edit.add_argument('--filter-id', type=int, default=None, help="Filter ID (use this OR --filter, not both)")
    subframe_edit.add_argument('--exposure-time', type=float, default=None, help="Exposure time (seconds)")
    subframe_edit.add_argument('--goal-count', type=int, default=None, help="Target number of subframes")
    subframe_edit.add_argument('--active', action='store_true', help="Set subframe active")
    subframe_edit.add_argument('--inactive', action='store_true', help="Set subframe inactive")
    subframe_remove = subframe_sub.add_parser('remove', help="Remove a subframe from a project")
    subframe_remove.add_argument('project_id', type=int, help="Project ID")
    subframe_remove.add_argument('subframe_id', type=int, help="Subframe ID to remove")
    project_stats_parser = project_sub.add_parser('stats', help="Show task statistics for a project")
    project_stats_parser.add_argument('project_id', type=int, help="Project ID")
    project_task_add = project_sub.add_parser('task-add', help="Assign a task to a project")
    project_task_add.add_argument('project_id', type=int, help="Project ID")
    project_task_add.add_argument('task_id', type=int, help="Task ID to add to the project")
    project_task_remove = project_sub.add_parser('task-remove', help="Remove a task from a project")
    project_task_remove.add_argument('project_id', type=int, help="Project ID")
    project_task_remove.add_argument('task_id', type=int, help="Task ID to remove from the project")

    telescopes_parser = subparsers.add_parser('telescopes', help="List telescopes")
    telescopes_parser.add_argument('--sort-by', choices=['scope_id', 'name', 'focal', 'active'], default='scope_id', help="Sort by field")
    telescopes_parser.add_argument('--sort-order', choices=['asc', 'desc'], default='asc', help="Sort order")

    telescope_parser = subparsers.add_parser('telescope', help="Add, edit, show telescope or manage sensor/filters")
    telescope_sub = telescope_parser.add_subparsers(dest='telescope_command', help="Telescope subcommand")
    t_add = telescope_sub.add_parser('add', help="Add a new telescope (scope_id auto-assigned if not given)")
    t_add.add_argument('name', help="Telescope name")
    t_add.add_argument('--scope-id', type=int, default=None, help="Telescope ID (optional; next available if omitted)")
    t_add.add_argument('--descr', help="Description")
    t_add.add_argument('--min-dec', type=float, help="Min declination")
    t_add.add_argument('--max-dec', type=float, help="Max declination")
    t_add.add_argument('--focal', type=float, help="Focal length (mm)")
    t_add.add_argument('--aperture', type=float, help="Aperture (mm)")
    t_add.add_argument('--lon', type=float, help="Longitude")
    t_add.add_argument('--lat', type=float, help="Latitude")
    t_add.add_argument('--alt', type=float, help="Altitude")
    t_add.add_argument('--sensor-id', type=int, default=None, help="Sensor ID (0 or omit = none)")
    t_add.add_argument('--active', action='store_true', default=True, help="Telescope is active (default)")
    t_add.add_argument('--inactive', action='store_true', help="Create telescope as inactive")
    t_edit = telescope_sub.add_parser('edit', help="Edit an existing telescope")
    t_edit.add_argument('scope_id', type=int, help="Telescope scope_id")
    t_edit.add_argument('--name', help="Telescope name")
    t_edit.add_argument('--descr', help="Description")
    t_edit.add_argument('--min-dec', type=float, help="Min declination")
    t_edit.add_argument('--max-dec', type=float, help="Max declination")
    t_edit.add_argument('--focal', type=float, help="Focal length (mm)")
    t_edit.add_argument('--aperture', type=float, help="Aperture (mm)")
    t_edit.add_argument('--lon', type=float, help="Longitude")
    t_edit.add_argument('--lat', type=float, help="Latitude")
    t_edit.add_argument('--alt', type=float, help="Altitude")
    t_edit.add_argument('--sensor-id', type=int, default=None, help="Sensor ID (0 to remove)")
    t_edit.add_argument('--active', action='store_true', help="Set active")
    t_edit.add_argument('--inactive', action='store_true', help="Set inactive")
    t_show = telescope_sub.add_parser('show', help="Show telescope details (sensor + filters)")
    t_show.add_argument('scope_id', type=int, help="Telescope scope_id")
    t_sensor = telescope_sub.add_parser('set-sensor', help="Set or clear telescope sensor (0 = remove)")
    t_sensor.add_argument('scope_id', type=int, help="Telescope scope_id")
    t_sensor.add_argument('sensor_id', type=int, help="Sensor ID (0 to remove)")
    t_addfilter = telescope_sub.add_parser('add-filter', help="Add a filter to the telescope")
    t_addfilter.add_argument('scope_id', type=int, help="Telescope scope_id")
    t_addfilter.add_argument('filter_id', type=int, help="Filter ID to add")
    t_remfilter = telescope_sub.add_parser('remove-filter', help="Remove a filter from the telescope")
    t_remfilter.add_argument('scope_id', type=int, help="Telescope scope_id")
    t_remfilter.add_argument('filter_id', type=int, help="Filter ID to remove")

    args = parser.parse_args()

    # db commands: version, migrate, backup, stats
    if args.command == "db":
        if args.db_command == "version":
            return db_version()  # see cmd_basic.py
        if args.db_command == "migrate":
            return migrate(args)  # see cmd_db_migrate.py
        if args.db_command == "backup":
            return backup(args)  # see cmd_backup.py
        if args.db_command == "stats":
            return stats()  # see cmd_stats.py
        return parser.print_help()
    if args.command == "data":
        if args.data_command == "distrib":
            return histogram_show(args)  # see cmd_stats.py
        if args.data_command == "groups":
            return groups(args)  # see cmd_stats.py
        if args.data_command == "catalog":
            return catalog(args)  # see cmd_catalog.py
        return parser.print_help()
    if args.command == "config":
        return config_show()  # see cmd_basic.py
    if args.command == "repo":
        return repo(args)  # see cmd_repo.py
    if args.command == "version":
        return version()
    if args.command == "filters":
        list_filters(active_only=args.active_only, sort_by=args.sort_by, sort_order=args.sort_order)
        return 0
    if args.command == "filter":
        if args.filter_command == "add":
            active = getattr(args, 'active', True) and not getattr(args, 'inactive', False)
            return 0 if add_filter(args.short_name, args.full_name, args.url, active) is not None else 1
        if args.filter_command == "edit":
            active = None
            if getattr(args, 'active', False):
                active = True
            if getattr(args, 'inactive', False):
                active = False
            return 0 if edit_filter(args.filter_id, args.short_name, args.full_name, args.url, active) else 1
        return filter_parser.print_help() or 1
    if args.command == "sensors":
        list_sensors(active_only=args.active_only, sort_by=args.sort_by, sort_order=args.sort_order)
        return 0
    if args.command == "sensor":
        if args.sensor_command == "add":
            active = getattr(args, 'active', True) and not getattr(args, 'inactive', False)
            return 0 if add_sensor(
                args.name,
                resx=args.resx,
                resy=args.resy,
                pixel_x=args.pixel_x,
                pixel_y=args.pixel_y,
                bits=getattr(args, 'bits', 0),
                width=getattr(args, 'width', None),
                height=getattr(args, 'height', None),
                vendor=getattr(args, 'vendor', None),
                url=getattr(args, 'url', None),
                active=active
            ) is not None else 1
        if args.sensor_command == "edit":
            active = None
            if getattr(args, 'active', False):
                active = True
            if getattr(args, 'inactive', False):
                active = False
            return 0 if edit_sensor(
                args.sensor_id,
                name=getattr(args, 'name', None),
                resx=getattr(args, 'resx', None),
                resy=getattr(args, 'resy', None),
                pixel_x=getattr(args, 'pixel_x', None),
                pixel_y=getattr(args, 'pixel_y', None),
                bits=getattr(args, 'bits', None),
                width=getattr(args, 'width', None),
                height=getattr(args, 'height', None),
                vendor=getattr(args, 'vendor', None),
                url=getattr(args, 'url', None),
                active=active
            ) else 1
        return sensor_parser.print_help() or 1
    if args.command == "projects":
        if args.project_id is not None:
            return show_project(args.project_id) or 0
        list_projects(scope_id=getattr(args, 'scope_id', None))
        return 0
    if args.command == "project":
        if args.project_command == "add":
            active = getattr(args, 'active', True) and not getattr(args, 'inactive', False)
            pid = add_project(
                args.name,
                scope_id=args.scope_id,
                description=getattr(args, 'description', '') or '',
                ra=getattr(args, 'ra', None),
                dec=getattr(args, 'dec', None),
                active=active
            )
            if pid is None:
                print("Failed to add project: name not in catalog (provide --ra and --dec) or invalid scope_id.", file=sys.stderr)
                return 1
            print(f"Created project_id={pid}")
            return 0
        if args.project_command == "edit":
            active = None
            if getattr(args, 'active', False):
                active = True
            if getattr(args, 'inactive', False):
                active = False
            ok = edit_project(
                args.project_id,
                name=getattr(args, 'name', None),
                description=getattr(args, 'description', None),
                scope_id=getattr(args, 'scope_id', None),
                ra=getattr(args, 'ra', None),
                dec=getattr(args, 'dec', None),
                active=active
            )
            return 0 if ok else 1
        if args.project_command == "show":
            return show_project(args.project_id) or 0
        if args.project_command == "stats":
            return project_stats(args.project_id) or 0
        if args.project_command == "task-add":
            return 0 if add_task_to_project(args.project_id, args.task_id) else 1
        if args.project_command == "task-remove":
            return 0 if remove_task_from_project(args.project_id, args.task_id) else 1
        if args.project_command == "subframe":
            if args.subframe_command == "add":
                has_filter = bool(getattr(args, 'filter', None) and str(getattr(args, 'filter', '')).strip())
                has_filter_id = getattr(args, 'filter_id', None) is not None
                if has_filter and has_filter_id:
                    print("Error: specify only one of --filter or --filter-id.", file=sys.stderr)
                    return 1
                if not has_filter and not has_filter_id:
                    print("Error: specify either --filter (short name) or --filter-id.", file=sys.stderr)
                    return 1
                filter_id = args.filter_id if has_filter_id else get_filter_id_by_short_name(args.filter)
                if filter_id is None:
                    print("Error: filter not found (invalid --filter-id or unknown short name).", file=sys.stderr)
                    return 1
                active = getattr(args, 'active', True) and not getattr(args, 'inactive', False)
                sid = add_project_subframe(
                    args.project_id,
                    filter_id=filter_id,
                    exposure_time=args.exposure_time,
                    goal_count=getattr(args, 'goal_count', None),
                    active=active
                )
                if sid is not None:
                    print(f"Added subframe ID: {sid}")
                    return 0
                print("Failed to add subframe: project not found or invalid filter.", file=sys.stderr)
                return 1
            if args.subframe_command == "edit":
                has_filter = bool(getattr(args, 'filter', None) and str(getattr(args, 'filter', '')).strip())
                has_filter_id = getattr(args, 'filter_id', None) is not None
                if has_filter and has_filter_id:
                    print("Error: specify only one of --filter or --filter-id.", file=sys.stderr)
                    return 1
                filter_id = None
                if has_filter_id:
                    filter_id = args.filter_id
                elif has_filter:
                    filter_id = get_filter_id_by_short_name(args.filter)
                    if filter_id is None:
                        print("Error: filter short name not found.", file=sys.stderr)
                        return 1
                active = None
                if getattr(args, 'active', False):
                    active = True
                if getattr(args, 'inactive', False):
                    active = False
                ok = edit_project_subframe(
                    args.project_id,
                    args.subframe_id,
                    filter_id=filter_id,
                    exposure_time=getattr(args, 'exposure_time', None),
                    goal_count=getattr(args, 'goal_count', None),
                    active=active
                )
                return 0 if ok else 1
            if args.subframe_command == "remove":
                return 0 if remove_project_subframe(args.project_id, args.subframe_id) else 1
            return subframe_parser.print_help() or 1
        return project_parser.print_help() or 1
    if args.command == "telescopes":
        list_telescopes(sort_by=args.sort_by, sort_order=args.sort_order)
        return 0
    if args.command == "telescope":
        if args.telescope_command == "add":
            active = getattr(args, 'active', True) and not getattr(args, 'inactive', False)
            return 0 if add_telescope(
                args.name,
                scope_id=getattr(args, 'scope_id', None),
                descr=getattr(args, 'descr', None),
                min_dec=getattr(args, 'min_dec', None),
                max_dec=getattr(args, 'max_dec', None),
                focal=getattr(args, 'focal', None),
                aperture=getattr(args, 'aperture', None),
                lon=getattr(args, 'lon', None),
                lat=getattr(args, 'lat', None),
                alt=getattr(args, 'alt', None),
                sensor_id=getattr(args, 'sensor_id', None),
                active=active
            ) is not None else 1
        if args.telescope_command == "edit":
            active = None
            if getattr(args, 'active', False):
                active = True
            if getattr(args, 'inactive', False):
                active = False
            return 0 if edit_telescope(
                args.scope_id,
                name=getattr(args, 'name', None),
                descr=getattr(args, 'descr', None),
                min_dec=getattr(args, 'min_dec', None),
                max_dec=getattr(args, 'max_dec', None),
                focal=getattr(args, 'focal', None),
                aperture=getattr(args, 'aperture', None),
                lon=getattr(args, 'lon', None),
                lat=getattr(args, 'lat', None),
                alt=getattr(args, 'alt', None),
                sensor_id=getattr(args, 'sensor_id', None),
                active=active
            ) else 1
        if args.telescope_command == "show":
            return show_telescope(args.scope_id)
        if args.telescope_command == "set-sensor":
            return 0 if set_telescope_sensor(args.scope_id, args.sensor_id) else 1
        if args.telescope_command == "add-filter":
            return 0 if add_telescope_filter(args.scope_id, args.filter_id) else 1
        if args.telescope_command == "remove-filter":
            return 0 if remove_telescope_filter(args.scope_id, args.filter_id) else 1
        return telescope_parser.print_help() or 1
    return parser.print_help()


def version():
    """
    Prints the version of the Hevelius project.
    """
    print(f"Hevelius {hevelius_version()}")


if __name__ == '__main__':
    run()
